{
  "manifest_version": 3,
  "name": "LeadScaper Pro By Devify",
  "version": "1.0.0",
  "description": "Extract high-quality business leads from Google Maps. Scrape names, emails, phone numbers, ratings, websites, and more — export to CSV, Excel, or JSON.",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage",
    "sidePanel",
    "alarms",
    "contextMenus"
  ],
  "host_permissions": [
    "*://www.google.com/maps/*",
    "*://maps.google.com/*",
    "*://web.whatsapp.com/*"
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "LeadScaper Pro By Devify"
  },
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.google.com/maps/*",
        "*://maps.google.com/*"
      ],
      "js": [
        "maps-scraper.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}